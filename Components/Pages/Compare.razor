@page "/compare/{EncodedTypeName}"
@page "/compare"
@using ODataMapper.Models
@using ODataMapper.Services
@inject MetadataStateService StateService
@rendermode InteractiveServer

<PageTitle>Compare Entities - OData Analyzer</PageTitle>

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Entities</a></li>
            <li class="breadcrumb-item active">Compare</li>
        </ol>
    </nav>

    <h1 class="text-primary mb-4"><i class="bi bi-layout-split"></i> Compare Entities</h1>

    @if (metadata == null)
    {
        <div class="alert alert-warning">
            <p>No metadata loaded. <a href="/">Go back and load metadata first.</a></p>
        </div>
    }
    else
    {
        @* Entity Selection with Search *@
        <div class="row mb-4">
            <div class="col-md-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">Left Entity</h6>
                        @if (LeftEntity != null)
                        {
                            <a href="/entity/@System.Net.WebUtility.UrlEncode(LeftEntity.FullTypeName)" class="btn btn-sm btn-light">
                                View Details →
                            </a>
                        }
                    </div>
                    <div class="card-body">
                        <div class="position-relative">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control"
                                       placeholder="@(LeftEntity != null ? LeftEntity.Name : "Search entity...")"
                                       @bind="leftSearch" @bind:event="oninput"
                                       @onfocus="() => leftDropdownOpen = true" />
                                @if (LeftEntity != null)
                                {
                                    <button class="btn btn-outline-secondary" @onclick="ClearLeft" title="Clear selection">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                            @if (leftDropdownOpen && LeftSearchResults.Any())
                            {
                                <div class="search-dropdown shadow">
                                    @foreach (var e in LeftSearchResults.Take(20))
                                    {
                                        <div class="search-dropdown-item @(e.FullTypeName == leftEntityType ? "active" : "")"
                                             @onclick="() => SelectLeft(e)">
                                            <strong>@e.Name</strong>
                                            <small class="text-muted d-block">@e.EntitySetName</small>
                                        </div>
                                    }
                                    @if (LeftSearchResults.Count() > 20)
                                    {
                                        <div class="search-dropdown-item text-muted text-center">
                                            <small>@(LeftSearchResults.Count() - 20) more — refine your search</small>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        @if (LeftEntity != null)
                        {
                            <div class="mt-2">
                                <span class="badge bg-primary">@LeftEntity.Name</span>
                                <small class="text-muted ms-1">@LeftEntity.EntitySetName</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-2 d-flex align-items-center justify-content-center">
                <button class="btn btn-outline-secondary" @onclick="SwapEntities" title="Swap left and right">
                    <span class="fs-3">⇄</span>
                </button>
            </div>
            <div class="col-md-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">Right Entity</h6>
                        @if (RightEntity != null)
                        {
                            <a href="/entity/@System.Net.WebUtility.UrlEncode(RightEntity.FullTypeName)" class="btn btn-sm btn-light">
                                View Details →
                            </a>
                        }
                    </div>
                    <div class="card-body">
                        <div class="position-relative">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control"
                                       placeholder="@(RightEntity != null ? RightEntity.Name : "Search entity...")"
                                       @bind="rightSearch" @bind:event="oninput"
                                       @onfocus="() => rightDropdownOpen = true" />
                                @if (RightEntity != null)
                                {
                                    <button class="btn btn-outline-secondary" @onclick="ClearRight" title="Clear selection">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                            @if (rightDropdownOpen && RightSearchResults.Any())
                            {
                                <div class="search-dropdown shadow">
                                    @foreach (var e in RightSearchResults.Take(20))
                                    {
                                        <div class="search-dropdown-item @(e.FullTypeName == rightEntityType ? "active" : "")"
                                             @onclick="() => SelectRight(e)">
                                            <strong>@e.Name</strong>
                                            <small class="text-muted d-block">@e.EntitySetName</small>
                                        </div>
                                    }
                                    @if (RightSearchResults.Count() > 20)
                                    {
                                        <div class="search-dropdown-item text-muted text-center">
                                            <small>@(RightSearchResults.Count() - 20) more — refine your search</small>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        @if (RightEntity != null)
                        {
                            <div class="mt-2">
                                <span class="badge bg-success">@RightEntity.Name</span>
                                <small class="text-muted ms-1">@RightEntity.EntitySetName</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Comparison Results *@
        @if (LeftEntity != null && RightEntity != null)
        {
            @* Summary *@
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0">Comparison Summary</h5>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-md-3">
                                    <h6>Properties</h6>
                                    <span class="badge bg-primary fs-6">@LeftEntity.Properties.Count</span>
                                    <span class="text-muted mx-1">vs</span>
                                    <span class="badge bg-success fs-6">@RightEntity.Properties.Count</span>
                                </div>
                                <div class="col-md-3">
                                    <h6>Shared Properties</h6>
                                    <span class="badge bg-secondary fs-6">@SharedProperties.Count()</span>
                                </div>
                                <div class="col-md-3">
                                    <h6>Only in @LeftEntity.Name</h6>
                                    <span class="badge bg-primary fs-6">@LeftOnlyProperties.Count()</span>
                                </div>
                                <div class="col-md-3">
                                    <h6>Only in @RightEntity.Name</h6>
                                    <span class="badge bg-success fs-6">@RightOnlyProperties.Count()</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Search + Tabs *@
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Filter properties by name..."
                               @bind="propertyFilter" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(propertyFilter))
                        {
                            <button class="btn btn-outline-secondary" @onclick="() => propertyFilter = string.Empty">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <ul class="nav nav-tabs mb-3">
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "all" ? "active" : "")" @onclick='() => activeTab = "all"'>
                        All Properties
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "shared" ? "active" : "")" @onclick='() => activeTab = "shared"'>
                        Shared (@SharedProperties.Count())
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "leftonly" ? "active" : "")" @onclick='() => activeTab = "leftonly"'>
                        Only in @LeftEntity.Name (@LeftOnlyProperties.Count())
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "rightonly" ? "active" : "")" @onclick='() => activeTab = "rightonly"'>
                        Only in @RightEntity.Name (@RightOnlyProperties.Count())
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "diff" ? "active" : "")" @onclick='() => activeTab = "diff"'>
                        Type Differences (@TypeDifferences.Count())
                    </button>
                </li>
            </ul>

            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                <table class="table table-sm table-hover">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Property Name</th>
                            <th class="text-primary">@LeftEntity.Name Type</th>
                            <th class="text-success">@RightEntity.Name Type</th>
                            <th>Status</th>
                            <th>Enum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in GetComparisonRows())
                        {
                            <tr class="@row.RowClass">
                                <td><strong>@row.Name</strong></td>
                                <td><code>@(row.LeftType ?? "—")</code></td>
                                <td><code>@(row.RightType ?? "—")</code></td>
                                <td>
                                    @switch (row.Status)
                                    {
                                        case "shared":
                                            <span class="badge bg-secondary">Shared</span>
                                            break;
                                        case "left-only":
                                            <span class="badge bg-primary">Left Only</span>
                                            break;
                                        case "right-only":
                                            <span class="badge bg-success">Right Only</span>
                                            break;
                                        case "type-diff":
                                            <span class="badge bg-danger">Type Changed</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (row.IsEnum)
                                    {
                                        <button class="btn btn-sm btn-outline-info py-0 px-1" @onclick="() => ShowEnum(row.EnumTypeName!)">
                                            View Values
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Navigation Properties Comparison *@
            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">@LeftEntity.Name Relationships (@LeftEntity.NavigationProperties.Count)</h6>
                        </div>
                        <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Name</th><th>Target</th><th>Type</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var nav in LeftEntity.NavigationProperties.OrderBy(n => n.Name))
                                    {
                                        <tr>
                                            <td>@nav.Name</td>
                                            <td><code>@nav.TargetEntityName</code></td>
                                            <td>
                                                <span class="badge @(nav.IsCollection ? "bg-success" : "bg-secondary")">
                                                    @nav.RelationshipType
                                                </span>
                                            </td>
                                            <td>
                                                @{
                                                    var leftTarget = GetEntityByShortName(nav.TargetEntityName);
                                                }
                                                @if (leftTarget != null)
                                                {
                                                    <a href="/entity/@System.Net.WebUtility.UrlEncode(leftTarget.FullTypeName)" class="btn btn-sm btn-outline-light py-0 px-1" title="View entity details">
                                                        →
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0">@RightEntity.Name Relationships (@RightEntity.NavigationProperties.Count)</h6>
                        </div>
                        <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Name</th><th>Target</th><th>Type</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var nav in RightEntity.NavigationProperties.OrderBy(n => n.Name))
                                    {
                                        <tr>
                                            <td>@nav.Name</td>
                                            <td><code>@nav.TargetEntityName</code></td>
                                            <td>
                                                <span class="badge @(nav.IsCollection ? "bg-success" : "bg-secondary")">
                                                    @nav.RelationshipType
                                                </span>
                                            </td>
                                            <td>
                                                @{
                                                    var rightTarget = GetEntityByShortName(nav.TargetEntityName);
                                                }
                                                @if (rightTarget != null)
                                                {
                                                    <a href="/entity/@System.Net.WebUtility.UrlEncode(rightTarget.FullTypeName)" class="btn btn-sm btn-outline-light py-0 px-1" title="View entity details">
                                                        →
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Enum Detail Modal *@
        @if (selectedEnum != null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title">Enum: @selectedEnum.Name</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseEnum"></button>
                        </div>
                        <div class="modal-body">
                            <p><strong>Full Name:</strong> <code>@selectedEnum.FullName</code></p>
                            <p><strong>Underlying Type:</strong> <code>@selectedEnum.UnderlyingType</code></p>
                            @if (selectedEnum.IsFlags)
                            {
                                <span class="badge bg-warning text-dark mb-2">Flags Enum</span>
                            }
                            <p class="text-muted mb-2">@selectedEnum.Members.Count available values:</p>
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-striped">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Name</th>
                                            <th>Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in selectedEnum.Members)
                                        {
                                            <tr>
                                                <td>@member.Name</td>
                                                <td><code>@(member.Value ?? "—")</code></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseEnum">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string? EncodedTypeName { get; set; }

    private ODataMetadataResult? metadata;
    private string leftEntityType = string.Empty;
    private string rightEntityType = string.Empty;
    private string activeTab = "all";
    private string propertyFilter = string.Empty;
    private ODataEnumType? selectedEnum;

    // Search-select state
    private string leftSearch = string.Empty;
    private string rightSearch = string.Empty;
    private bool leftDropdownOpen;
    private bool rightDropdownOpen;

    private ODataEntity? LeftEntity => metadata?.Entities.FirstOrDefault(e => e.FullTypeName == leftEntityType);
    private ODataEntity? RightEntity => metadata?.Entities.FirstOrDefault(e => e.FullTypeName == rightEntityType);

    private IEnumerable<ODataEntity> LeftSearchResults
    {
        get
        {
            if (metadata == null) return [];
            var entities = metadata.Entities.Where(e => !string.IsNullOrEmpty(e.EntitySetName));
            if (!string.IsNullOrWhiteSpace(leftSearch))
            {
                var term = leftSearch.Trim();
                entities = entities.Where(e =>
                    e.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    e.EntitySetName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }
            return entities.OrderBy(e => e.Name);
        }
    }

    private IEnumerable<ODataEntity> RightSearchResults
    {
        get
        {
            if (metadata == null) return [];
            var entities = metadata.Entities.Where(e => !string.IsNullOrEmpty(e.EntitySetName));
            if (!string.IsNullOrWhiteSpace(rightSearch))
            {
                var term = rightSearch.Trim();
                entities = entities.Where(e =>
                    e.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    e.EntitySetName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }
            return entities.OrderBy(e => e.Name);
        }
    }

    private IEnumerable<ODataProperty> SharedProperties =>
        LeftEntity?.Properties.Where(p => RightEntity?.Properties.Any(rp => rp.Name == p.Name) == true) ?? [];

    private IEnumerable<ODataProperty> LeftOnlyProperties =>
        LeftEntity?.Properties.Where(p => RightEntity?.Properties.All(rp => rp.Name != p.Name) == true) ?? [];

    private IEnumerable<ODataProperty> RightOnlyProperties =>
        RightEntity?.Properties.Where(p => LeftEntity?.Properties.All(lp => lp.Name != p.Name) == true) ?? [];

    private IEnumerable<(string Name, string LeftType, string RightType)> TypeDifferences =>
        SharedProperties
            .Select(lp => (lp.Name, lp.Type, Right: RightEntity?.Properties.FirstOrDefault(rp => rp.Name == lp.Name)?.Type ?? ""))
            .Where(x => x.Type != x.Right);

    protected override void OnParametersSet()
    {
        metadata = StateService.CurrentMetadata;
        if (metadata == null || string.IsNullOrEmpty(EncodedTypeName)) return;

        var typeName = System.Net.WebUtility.UrlDecode(EncodedTypeName);
        var entity = metadata.Entities.FirstOrDefault(e => e.FullTypeName == typeName);
        if (entity != null)
        {
            leftEntityType = entity.FullTypeName;
            // Auto-select a related version if available
            if (entity.HasMultipleVersions && entity.RelatedVersions.Count > 0)
            {
                var relatedSetName = entity.RelatedVersions.First();
                var relatedEntity = metadata.Entities.FirstOrDefault(e => e.EntitySetName == relatedSetName);
                if (relatedEntity != null)
                {
                    rightEntityType = relatedEntity.FullTypeName;
                }
            }
        }
    }

    private void SelectLeft(ODataEntity entity)
    {
        leftEntityType = entity.FullTypeName;
        leftSearch = string.Empty;
        leftDropdownOpen = false;
    }

    private void SelectRight(ODataEntity entity)
    {
        rightEntityType = entity.FullTypeName;
        rightSearch = string.Empty;
        rightDropdownOpen = false;
    }

    private void ClearLeft()
    {
        leftEntityType = string.Empty;
        leftSearch = string.Empty;
    }

    private void ClearRight()
    {
        rightEntityType = string.Empty;
        rightSearch = string.Empty;
    }

    private void SwapEntities()
    {
        (leftEntityType, rightEntityType) = (rightEntityType, leftEntityType);
    }

    private void ShowEnum(string enumTypeName)
    {
        selectedEnum = StateService.FindEnum(enumTypeName);
    }

    private void CloseEnum() => selectedEnum = null;

    private ODataEntity? GetEntityByShortName(string name)
    {
        return metadata?.Entities.FirstOrDefault(e => e.Name == name || e.EntityTypeName == name);
    }

    private record ComparisonRow(string Name, string? LeftType, string? RightType, string Status, string RowClass, bool IsEnum, string? EnumTypeName);

    private IEnumerable<ComparisonRow> GetComparisonRows()
    {
        if (LeftEntity == null || RightEntity == null) return [];

        var leftProps = LeftEntity.Properties.ToDictionary(p => p.Name);
        var rightProps = RightEntity.Properties.ToDictionary(p => p.Name);
        var allNames = leftProps.Keys.Union(rightProps.Keys).OrderBy(n => n);

        var rows = new List<ComparisonRow>();
        foreach (var name in allNames)
        {
            // Apply property name filter
            if (!string.IsNullOrWhiteSpace(propertyFilter) &&
                !name.Contains(propertyFilter, StringComparison.OrdinalIgnoreCase))
                continue;

            var hasLeft = leftProps.TryGetValue(name, out var left);
            var hasRight = rightProps.TryGetValue(name, out var right);

            string status;
            string rowClass;
            if (hasLeft && hasRight)
            {
                if (left!.Type != right!.Type)
                {
                    status = "type-diff";
                    rowClass = "table-danger";
                }
                else
                {
                    status = "shared";
                    rowClass = "";
                }
            }
            else if (hasLeft)
            {
                status = "left-only";
                rowClass = "table-primary";
            }
            else
            {
                status = "right-only";
                rowClass = "table-success";
            }

            // Apply tab filter
            if (activeTab == "shared" && status != "shared") continue;
            if (activeTab == "leftonly" && status != "left-only") continue;
            if (activeTab == "rightonly" && status != "right-only") continue;
            if (activeTab == "diff" && status != "type-diff") continue;

            // Determine if either side is an enum
            var isEnum = (left?.IsEnum == true) || (right?.IsEnum == true);
            var enumTypeName = left?.EnumTypeName ?? right?.EnumTypeName;

            rows.Add(new ComparisonRow(name, left?.DisplayType, right?.DisplayType, status, rowClass, isEnum, enumTypeName));
        }

        return rows;
    }
}
