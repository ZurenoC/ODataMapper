@page "/entity/{EncodedTypeName}"
@using ODataMapper.Models
@using ODataMapper.Components.Pages
@rendermode InteractiveServer

<PageTitle>@(entity?.Name ?? "Entity") - OData Analyzer</PageTitle>

<div class="container-fluid">
    @if (entity == null)
    {
        <div class="alert alert-warning">
            <h4>Entity not found</h4>
            <p>No metadata loaded or entity type not found. <a href="/">Go back and load metadata first.</a></p>
        </div>
    }
    else
    {
        @* Header *@
        <div class="row mb-4">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Entities</a></li>
                        <li class="breadcrumb-item active">@entity.Name</li>
                    </ol>
                </nav>

                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1 class="text-primary">@entity.Name</h1>
                        <p class="text-muted mb-1">
                            <strong>Full Type:</strong> <code>@entity.FullTypeName</code>
                        </p>
                        @if (!string.IsNullOrEmpty(entity.EntitySetName))
                        {
                            <p class="mb-1">
                                <strong>EntitySet:</strong> <code>@entity.EntitySetName</code>
                                <span class="ms-2 text-muted">URL:</span> <code>@entity.EntitySetUrl</code>
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(entity.BaseType))
                        {
                            <p class="mb-1">
                                <strong>Inherits from:</strong> <code>@entity.BaseType</code>
                            </p>
                        }
                    </div>
                    <div>
                        @if (entity.HasMultipleVersions)
                        {
                            <div class="alert alert-warning py-2 px-3 mb-0">
                                <strong>Versions exist:</strong>
                                @foreach (var version in entity.RelatedVersions)
                                {
                                    <a href="/entity/@System.Net.WebUtility.UrlEncode(GetFullTypeForEntitySet(version))" class="badge bg-warning text-dark text-decoration-none me-1">@version</a>
                                }
                                <a href="/compare/@System.Net.WebUtility.UrlEncode(entity.FullTypeName)" class="btn btn-sm btn-warning ms-2">Compare</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Key Properties *@
        @if (entity.KeyProperties.Count > 0)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow-sm border-primary">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="bi bi-key"></i> Key Properties</h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Nullable</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var prop in entity.KeyProperties)
                                    {
                                        <tr>
                                            <td><strong>@prop.Name</strong></td>
                                            <td><code>@prop.DisplayType</code></td>
                                            <td>@(prop.IsNullable ? "Yes" : "No")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Properties Section *@
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-list-ul"></i> Properties (@entity.Properties.Count)</h5>
                        <div class="input-group" style="max-width: 300px;">
                            <input type="text" class="form-control form-control-sm" placeholder="Filter properties..."
                                   @bind="propertySearch" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Nullable</th>
                                        <th>Max Length</th>
                                        <th>Enum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var prop in FilteredProperties)
                                    {
                                        <tr class="@(prop.IsKey ? "table-primary" : "") @(prop.IsEnum ? "table-info" : "")">
                                            <td>
                                                <strong>@prop.Name</strong>
                                                @if (prop.IsKey)
                                                {
                                                    <span class="badge bg-primary ms-1">KEY</span>
                                                }
                                            </td>
                                            <td><code>@prop.DisplayType</code></td>
                                            <td>@(prop.IsNullable ? "✓" : "✗")</td>
                                            <td>@(prop.MaxLength?.ToString() ?? "—")</td>
                                            <td>
                                                @if (prop.IsEnum)
                                                {
                                                    <button class="btn btn-sm btn-outline-info" @onclick="() => ShowEnum(prop.EnumTypeName!)">
                                                        View Enum
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* Navigation Properties (Relationships) *@
        @if (entity.NavigationProperties.Count > 0)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-diagram-3"></i> Relationships (@entity.NavigationProperties.Count)</h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Target Entity</th>
                                        <th>Relationship</th>
                                        <th>Partner</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var nav in entity.NavigationProperties.OrderBy(n => n.Name))
                                    {
                                        <tr>
                                            <td><strong>@nav.Name</strong></td>
                                            <td><code>@nav.TargetEntityName</code></td>
                                            <td>
                                                @if (nav.IsCollection)
                                                {
                                                    <span class="badge bg-success">One-to-Many</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Many-to-One</span>
                                                }
                                            </td>
                                            <td>@(nav.Partner ?? "—")</td>
                                            <td>
                                                @{
                                                    var targetEntity = GetEntityByShortName(nav.TargetEntityName);
                                                }
                                                @if (targetEntity != null)
                                                {
                                                    <a href="/entity/@System.Net.WebUtility.UrlEncode(targetEntity.FullTypeName)" class="btn btn-sm btn-outline-primary">
                                                        Navigate →
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Enum Detail Modal *@
        @if (selectedEnum != null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title">Enum: @selectedEnum.Name</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseEnum"></button>
                        </div>
                        <div class="modal-body">
                            <p><strong>Full Name:</strong> <code>@selectedEnum.FullName</code></p>
                            <p><strong>Underlying Type:</strong> <code>@selectedEnum.UnderlyingType</code></p>
                            @if (selectedEnum.IsFlags)
                            {
                                <span class="badge bg-warning text-dark mb-2">Flags Enum</span>
                            }
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-striped">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Name</th>
                                            <th>Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in selectedEnum.Members)
                                        {
                                            <tr>
                                                <td>@member.Name</td>
                                                <td><code>@(member.Value ?? "—")</code></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CloseEnum">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string EncodedTypeName { get; set; } = string.Empty;

    private ODataEntity? entity;
    private ODataMetadataResult? metadata;
    private ODataEnumType? selectedEnum;
    private string propertySearch = string.Empty;

    private IEnumerable<ODataProperty> FilteredProperties
    {
        get
        {
            if (entity == null) return [];
            if (string.IsNullOrWhiteSpace(propertySearch)) return entity.Properties;
            return entity.Properties.Where(p =>
                p.Name.Contains(propertySearch, StringComparison.OrdinalIgnoreCase) ||
                p.DisplayType.Contains(propertySearch, StringComparison.OrdinalIgnoreCase));
        }
    }

    protected override void OnParametersSet()
    {
        metadata = Home.CurrentMetadata;
        if (metadata == null) return;

        var typeName = System.Net.WebUtility.UrlDecode(EncodedTypeName);
        entity = metadata.Entities.FirstOrDefault(e => e.FullTypeName == typeName)
                ?? metadata.Entities.FirstOrDefault(e => e.Name == typeName);
    }

    private void ShowEnum(string enumTypeName)
    {
        selectedEnum = metadata?.EnumTypes.FirstOrDefault(e => e.FullName == enumTypeName)
                    ?? metadata?.EnumTypes.FirstOrDefault(e => e.Name == enumTypeName);
    }

    private void CloseEnum() => selectedEnum = null;

    private ODataEntity? GetEntityByShortName(string name)
    {
        return metadata?.Entities.FirstOrDefault(e => e.Name == name || e.EntityTypeName == name);
    }

    private string GetFullTypeForEntitySet(string entitySetName)
    {
        var e = metadata?.Entities.FirstOrDefault(e => e.EntitySetName == entitySetName);
        return e?.FullTypeName ?? entitySetName;
    }
}
